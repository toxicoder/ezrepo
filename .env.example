# MCP Server Secrets — copy to .env (already gitignored)
# ALL VALUES BELOW ARE OPTIONAL.
# Servers will start and work even without keys (limited functionality until you add them).

GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
BRAVE_API_KEY=bsa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CONTEXT7_API_KEY=ctx7_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# How to get free keys:
# • GitHub:      https://github.com/settings/tokens (classic token, repo scope)
# • Brave Search: https://brave.com/search/api/
# • Context7:    https://upstash.com/context7
